{
    // Harness Plugin Configuration
    // Global config: ~/.config/opencode/harness.jsonc
    // Project config: <project>/.opencode/harness.jsonc (overrides global)

    "agents": {
        "orchestrator": {
            "model": "zai-coding-plan/glm-5.1",
            "temperature": 0.1,
            "variant": "high",
            "skills": ["*"],
            "mcps": ["*"],
            "hidden": false,
        },
        "reviewer": {
            "model": "openai/gpt-5.4",
            "temperature": 0.1,
            "variant": "high",
            "skills": ["requesting-code-review", "simplify", "web-design-guidelines"],
            "mcps": [],
            "deny_tools": ["write", "edit", "patch", "bash"],
            "hidden": false,
        },
        "advisor": {
            "model": "openai/gpt-5.4",
            "temperature": 0.1,
            "variant": "high",
            "skills": ["brainstorming", "systematic-debugging"],
            "mcps": [],
            "deny_tools": ["write", "edit", "patch", "bash"],
            "hidden": false,
        },
        "frontend": {
            "model": "zai-coding-plan/glm-5.1",
            "temperature": 0.1,
            "variant": "medium",
            "skills": ["vercel-react-best-practices", "vercel-composition-patterns", "receiving-code-review", "simplify", "verification-before-completion"],
            "mcps": [],
            "hidden": false,
        },
        "backend": {
            "model": "zai-coding-plan/glm-5.1",
            "temperature": 0.1,
            "variant": "high",
            "skills": ["receiving-code-review", "simplify", "verification-before-completion"],
            "mcps": [],
            "hidden": false,
        },
        "tester": {
            "model": "zai-coding-plan/glm-5.1",
            "temperature": 0.1,
            "variant": "high",
            "skills": ["test-driven-development", "dogfood", "agent-browser", "simplify", "verification-before-completion"],
            "mcps": [],
            "hidden": false,
        },
        "coder": {
            "model": "zai-coding-plan/glm-5.1",
            "temperature": 0.1,
            "variant": "medium",
            "skills": ["simplify", "receiving-code-review", "verification-before-completion"],
            "mcps": [],
            "hidden": false,
        },
        "designer": {
            "model": "openai/gpt-5.4",
            "temperature": 0.7,
            "variant": "medium",
            "skills": ["frontend-design", "ui-ux-pro-max", "excalidraw", "creative-ideation", "popular-web-designs", "agent-browser", "brainstorming"],
            "mcps": [],
            "deny_tools": ["bash"],
            "hidden": false,
        },
        "explorer": {
            "model": "zai-coding-plan/glm-5-turbo",
            "temperature": 0.1,
            "variant": "medium",
            "skills": [],
            "mcps": [],
            "deny_tools": ["write", "edit", "patch", "bash"],
            "hidden": false,
        },
        "librarian": {
            "model": "zai-coding-plan/glm-5-turbo",
            "temperature": 0.1,
            "variant": "medium",
            "skills": [],
            "mcps": ["context7", "grep_app", "web-search-prime", "web-reader", "zread", "zai-mcp-server"],
            "deny_tools": ["write", "edit", "patch", "bash"],
            "hidden": false,
        },
    },

    "harness": {
        // ─── Core ───
        "soft_to_hard_threshold": 2, // SOFT→HARD 승격: 위반 N회 시 자동 승격
        "escalation_threshold": 3, // 에러 복구 에스컬레이션 단계
        "max_recovery_stages": 5, // 에러 복구 최대 단계
        "max_subagent_depth": 3, // 서브에이전트 중첩 깊이 제한

        // ─── Rule Quality ───
        "regex_max_length": 10000, // 정규식 패턴 최대 길이 (catastrophic backtracking 방지)
        "scaffold_match_ratio": 0.6, // scaffold 파일 매칭 비율
        "candidate_threshold": 3, // 실수 패턴 candidate 생성 임계값 (동일 패턴 N회 반복 시)

        // ─── Storage ───
        "history_max_bytes": 1048576, // history.jsonl 최대 크기 (bytes, 초과 시 rotate)
        "search_max_results": 10, // memory search 최대 결과 수

        // ─── Shadow / Guarded Features (all default-off) ───
        "ack_guard_enabled": false, // multi-check ack acceptance (rule_written + rule_valid + not_prune_candidate)
        "semantic_compacting_enabled": false, // compacting 시 의미 기반 규칙 필터링
        "canary_enabled": false, // phase/signal canary — deterministic vs metadata 불일치 관찰
        "compacting_canary_enabled": false, // compacting canary — baseline vs semantic 선택 차이 관찰
        "prune_guard_enabled": false, // 비활성 규칙 자동 삭제 후보 기록
        "cross_project_promotion_guard_enabled": false, // 크로스 프로젝트 규칙 승격 후보 기록
        "auto_update_checker_enabled": false, // 세션 시작 시 npm 버전 체크 (warn-only)
    },

    // FallbackChain — 다중 모델 환경에서 rate limit 시 자동 전환
    // "fallback": {
    //     "enabled": true,
    //     "chains": {
    //         "backend": ["primary-model", "fallback-model-1", "fallback-model-2"],
    //     },
    // },

    // 에이전트 확장 필드 예시 (B1+B2)
    // "agents": {
    //     "frontend": {
    //         // model — 단일 문자열 또는 배열 (배열이면 첫 번째가 기본, 나머지는 FallbackChain)
    //         "model": ["provider/model-a", "provider/model-b"],
    //
    //         // variant — OpenCode 1순위 필드. 모델 변종 지정 (e.g. "high", "medium", "low")
    //         // 생략 시 OpenCode 기본값 사용
    //         "variant": "high",
    //
    //         // temperature — OpenCode 1순위 필드. 0=결정적, 1=무작위
    //         // 기본 정의값 사용 시 생략 가능
    //         "temperature": 0.1,
    //
    //         // hidden — OpenCode 1순위 필드. true면 @메뉴에서 숨김
    //         "hidden": false,
    //
    //         // skills — 접근 가능한 스킬 제어
    //         //   생략/빈배열([]) → 모든 스킬 접근 차단 (기본)
    //         //   ["*"]       → 모든 스킬 허용
    //         //   ["a", "b"]  → a, b만 허용
    //         //   ["*", "!x"] → x만 제외
    //         "skills": ["*"],
    //
    //         // mcps — 접근 가능한 MCP 서버 제어 (위 skills와 동일 문법)
    //         //   생략/빈배열 → 모든 MCP 접근 차단 (기본)
    //         //   ["mcp1"]    → mcp1만 허용
    //         //   ["*", "!mcp2"] → mcp2만 제외
    //         "mcps": ["context7", "grep_app"],
    //
    //         // options — provider-specific 파라미터 passthrough
    //         //   OpenCode가 인식하지 않는 키는 그대로 provider에 전달됨
    //         //   e.g. OpenAI reasoningEffort, maxCompletionTokens 등
    //         "options": { "reasoningEffort": "high" },
    //
    //         // prompt — 시스템 프롬프트 전체 교체 (파일 경로)
    //         //   생략 시 플러그인 내장 프롬프트 사용
    //         "prompt": "/path/to/custom-prompt.md",
    //
    //         // append_prompt — 기존 프롬프트 뒤에 추가 (파일 경로)
    //         //   내장 프롬프트를 유지하면서 추가 지시를 덧붙일 때
    //         "append_prompt": "/path/to/extra-instructions.md",
    //     },
    // },
}
