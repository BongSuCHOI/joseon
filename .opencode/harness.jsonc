    "harness": {
        "soft_to_hard_threshold": 2,
        "escalation_threshold": 3,
        "max_recovery_stages": 5,
        "history_max_bytes": 1048576,
        "regex_max_length": 10000,
        "scaffold_match_ratio": 0.6,
        "search_max_results": 10,
    },

